/// 3

import java.util.Scanner;
public class Exercicio3 {
    public static void main(String[] args) {
        Scanner leia = new Scanner(System.in);

        System.out.println("Informe o preço unitário do produto: ");
        Double precoUnitario = leia.nextDouble();

        System.out.println("Informe a quantidade vendida: ");
        int quantidade = leia.nextInt();

        Double valorTotal = precoUnitario * quantidade;

        System.out.println("O valor total a ser pago pelo cliente é: " + valorTotal);

        leia.close();
    }
}

